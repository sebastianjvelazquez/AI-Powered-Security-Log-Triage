APP_NAME="AI-Powered Security Log Triage Engine"
API_V1_PREFIX="/api/v1"
DATABASE_URL="sqlite:///./security_triage.db"
UPLOAD_STORAGE_DIR="./data/uploads"
MAX_UPLOAD_MB=10
ALLOWED_EXTENSIONS="log,txt,json,csv"
ALLOWED_MIME_TYPES="text/plain,application/json,text/csv,application/x-ndjson"
UPLOAD_RETENTION_DAYS=30
ENABLE_PII_REDACTION=false
PII_REDACTION_SALT=""
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/1"
LLM_PROVIDER="deterministic"
LLM_PROMPT_VERSION="v3"
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.1:8b"
OLLAMA_TIMEOUT_SECONDS=60
HOSTED_LLM_BASE_URL=""
HOSTED_LLM_ENDPOINT="/v1/triage"
HOSTED_LLM_MODEL="hosted-triage-model"
HOSTED_LLM_API_KEY=""
HOSTED_LLM_API_KEY_HEADER="Authorization"
HOSTED_LLM_TIMEOUT_SECONDS=60
HOSTED_LLM_RESPONSE_FIELD="response"
ASSET_CRITICALITY=1.0
FAILED_LOGIN_THRESHOLD=3
PORT_SCAN_THRESHOLD=5
CORRELATION_WINDOW_MINUTES=120
THREAT_INTEL_CACHE_HOURS=24
GEO_VELOCITY_WINDOW_MINUTES=60
LOG_LEVEL="INFO"
RATE_LIMIT_WINDOW_SECONDS=60
READ_RATE_LIMIT=120
UPLOAD_RATE_LIMIT=20
REVIEW_RATE_LIMIT=60
VIEWER_API_TOKEN="viewer-dev-token-change-me"
ANALYST_API_TOKEN="analyst-dev-token-change-me"
ADMIN_API_TOKEN="admin-dev-token-change-me"
FRONTEND_ORIGIN="http://localhost:5173"
